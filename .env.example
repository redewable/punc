# =====================================================================
# $PUNC — env vars. Copy to .env.local for local dev. Mirror in Vercel.
# Anything starting with NEXT_PUBLIC_ is exposed to the browser bundle.
# =====================================================================

# --- Token identity (REQUIRED after launch) ---
NEXT_PUBLIC_MINT_ADDRESS=PASTE_PUMPFUN_MINT_HERE
NEXT_PUBLIC_TOKEN_SYMBOL=PUNC
NEXT_PUBLIC_TOKEN_NAME=Purple Unc

# --- Socials (optional but recommended) ---
NEXT_PUBLIC_TWITTER_URL=
NEXT_PUBLIC_TELEGRAM_URL=
NEXT_PUBLIC_DISCORD_URL=

# --- Solana RPC ---
# Fallback used when HELIUS_API_KEY is not set. The public endpoint rate-limits
# getProgramAccounts hard — fine for local dev, NOT fine for production.
NEXT_PUBLIC_SOLANA_RPC=https://api.mainnet-beta.solana.com

# REQUIRED for production. Free tier handles the holder dashboard fine.
# https://helius.dev → create project → copy API key.
HELIUS_API_KEY=

# --- Leaderboard ETL (Vercel KV — OPTIONAL) ---
# When all three are set, /api/holders/snapshot will persist top-50 snapshots
# and /api/holders will compute 24h rank movement. Without these, the holder
# dashboard still works but won't show movement deltas.
# Vercel dashboard → Storage → Create KV → "Connect Project" auto-injects these.
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# Secret used to gate the cron snapshot endpoint. Generate with:
#   openssl rand -hex 32
# Set the same value in vercel.json's cron header OR Vercel auto-signs.
CRON_SECRET=

# --- Cousin-rank NFT mint (OPTIONAL — only if /cousin-rank is enabled) ---
# Base58-encoded secret key of the mint authority wallet. NEVER commit. NEVER
# expose to the client. Fund it with a small amount of SOL to cover rent.
# Generate one with: solana-keygen new --no-bip39-passphrase
COUSIN_RANK_MINT_AUTHORITY_SECRET=
# Base URL where the NFT metadata JSON will live. Default: this site's
# /api/cousin-rank/metadata route. Override if you host metadata on Arweave.
COUSIN_RANK_METADATA_BASE=
